# Environment variables for docker compose (all three stacks: prod / dev / v4).
# Copy this file to .env and fill in real values. .env is gitignored — NEVER
# commit it (it carries the real DB password and bank-feed API key).
#
# docker compose reads .env from this directory automatically.

# --- Required ---

# PostgreSQL password for the `fin` user. No default — compose fails fast if
# unset. Rotate with: ALTER USER fin PASSWORD '...'; then `docker compose up -d`.
POSTGRES_PASSWORD=replace-with-strong-password

# --- bank-feed microservice (CR021/CR022) ---
# host.docker.internal resolves to the host (compose files set extra_hosts on
# Linux). Override if bank-feed runs elsewhere.
BANK_FEED_URL=http://host.docker.internal:3007
BANK_FEED_API_KEY=replace-with-bank-feed-api-key

# --- Optional ---

# Local LLM gateway for the AI Review feature (ocr-llm, via Tailscale/LAN).
# LLM_GATEWAY_URL=http://192.168.1.61:8080

# Comma-separated CORS allowlist override (defaults cover dev/prod/Tailscale).
# CORS_ORIGINS=http://localhost:5174,https://fin.example.ts.net

# Auto-managed by Scripts/bump-version.sh — safe to leave out initially.
VITE_APP_VERSION=0.0.0
